---
const { prevPost, nextPost } = Astro.props;
---

<div class="flex flex-row justify-between gap-1.5 sm:gap-3">
	{
		prevPost?.slug ? (
			<a
				href={`/blog/${prevPost?.slug}`}
				class="group min-w-32 flex flex-nowrap items-center justify-center rounded-full border border-black/15 px-4 py-2 gap-2 no-underline transition-colors duration-300 ease-in-out bg-white dark:bg-headerDark hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/15 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					class="size-5 fill-none stroke-current stroke-2"
				>
					<line
						x1="5"
						y1="12"
						x2="19"
						y2="12"
						class="translate-x-3 scale-x-0 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-hover:scale-x-100 group-focus-visible:translate-x-0 group-focus-visible:scale-x-100"
					/>
					<polyline
						points="12 5 5 12 12 19"
						class="translate-x-1 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-focus-visible:translate-x-0"
					/>
				</svg>
				<div>Previous</div>
			</a>
		) : (
			<div class="invisible" />
		)
	}

	{
		nextPost?.slug ? (
			<a
				href={`/blog/${nextPost?.slug}`}
				class="group min-w-32 flex flex-row-reverse flex-nowrap items-center justify-center rounded-full border border-black/15 px-4 py-2 gap-2 no-underline transition-colors duration-300 ease-in-out bg-white dark:bg-headerDark hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/15 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					class="size-5 fill-none stroke-current stroke-2"
				>
					<line
						x1="5"
						y1="12"
						x2="19"
						y2="12"
						class="translate-x-3 scale-x-0 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-hover:scale-x-100 group-focus-visible:translate-x-0 group-focus-visible:scale-x-100"
					/>
					<polyline
						points="12 5 19 12 12 19"
						class="-translate-x-1 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-focus-visible:translate-x-0"
					/>
				</svg>
				<div>Next</div>
			</a>
		) : (
			<div class="invisible" />
		)
	}
</div>
