				<section class="animate">
					<h2 class="font-title text-3xl md:text-4xl">
						Hello there 👋! Take a look at my digital garden. It's
						so me. Let's <button
							class="text-link dark:text-linkDark hover:underline"
							onclick="document.getElementById('socials').scrollIntoView({behavior: 'smooth'});"
							>connect</button
						>.
					</h2>
				</section>

				<section class="animate space-y-6">
					<h2
						class="heading text-xl md:text-2xl text-black dark:text-white"
					>
						Quick Links
					</h2>
					<QuickLinks />
				</section>

				<section class="animate space-y-6">
					<div
						class="flex flex-wrap items-center justify-between gap-y-2"
					>
						<h2
							class="heading text-xl md:text-2xl text-black dark:text-white"
						>
							Latest Posts
						</h2>
						<HeadLink href="/blog">See all posts</HeadLink>
					</div>
					<ul class="not-prose flex flex-col gap-4">
						{
							blog.map((post) => (
								<li>
									<ArrowCard entry={post} />
								</li>
							))
						}
					</ul>
				</section>

				<section class="animate space-y-6">
					<div
						class="flex flex-wrap items-center justify-between gap-y-2"
					>
						<h2
							class="heading text-xl md:text-2xl text-black dark:text-white"
						>
							Currently
						</h2>
						<HeadLink href="/blog">See all lists</HeadLink>
					</div>
					<RecentUpdates />
				</section>

				<section class="animate space-y-6">
					<div
						class="flex flex-wrap items-center justify-between gap-y-2"
					>
						<h2
							class="heading text-xl md:text-2xl text-black dark:text-white"
						>
							Work Experience
						</h2>
						<HeadLink href="/about">See all work</HeadLink>
					</div>
					<ul class="flex flex-col space-y-4">
						{
							work.map((entry) => (
								<li>
									<div class="text-sm opacity-85">
										{dateRange(
											entry.data.dateStart,
											entry.data.dateEnd,
										)}
									</div>
									<div class="font-semibold text-black dark:text-white">
										{entry.data.company}
									</div>
									<div class="opacity-85">
										{entry.data.role}
									</div>
									<article>
										<entry.Content />
									</article>
								</li>
							))
						}
					</ul>
				</section>

				<section class="animate space-y-4" id="socials">
					<h2
						class="heading text-xl md:text-2xl text-black dark:text-white"
					>
						Let's Connect
					</h2>
					<article>
						<p>
							If you want to get in touch with me about something,
							see what I'm all about or just to say hi, reach out
							on social media or send me an email.
						</p>
					</article>
					<ul class="not-prose flex flex-wrap gap-2">
						{
							SOCIALS.map((SOCIAL) => (
								<li class="flex gap-x-2 text-nowrap">
									<Link
										href={SOCIAL.HREF}
										external
										aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
									>
										{SOCIAL.NAME}
									</Link>
									{"/"}
								</li>
							))
						}
						<li class="line-clamp-1">
							<Link
								href={`mailto:${SITE.EMAIL}`}
								aria-label={`Email ${SITE.TITLE}`}
							>
								Email me
							</Link>
						</li>
					</ul>
				</section>
			</div>
		</aside>
	</Container>
</Layout>
